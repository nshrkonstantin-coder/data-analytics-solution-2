{
  "tests": [
    {
      "name": "Check access without token",
      "method": "GET",
      "path": "/?action=check-access",
      "expectedStatus": 400,
      "expectedBody": {"access": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get payment info for non-existent product",
      "method": "GET",
      "path": "/?action=payment-info&product_id=99999",
      "expectedStatus": 404,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Create order without auth",
      "method": "POST",
      "path": "/?action=create",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get my orders without auth",
      "method": "GET",
      "path": "/?action=my-orders",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
